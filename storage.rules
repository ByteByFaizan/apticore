rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Resume Upload Rules ──
    // Only authenticated users can upload to their batch folder
    match /batches/{batchId}/resumes/{fileName} {
      // Allow read only for authenticated users (Admin SDK bypasses these)
      allow read: if request.auth != null;

      // Allow upload: authenticated + valid file type + size limit
      allow create: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // 10MB max
        && (request.resource.contentType.matches('application/pdf')
            || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document'));

      // No update or delete from client
      allow update, delete: if false;
    }

    // ── Default: deny all ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
