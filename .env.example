# ════════════════════════════════════════════════
# AptiCore — Environment Variables
# Copy to .env.local and fill in values
# ════════════════════════════════════════════════

# ── Firebase Client (public, safe for browser) ──
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# ── AI Config (server-side only — NEVER prefix with NEXT_PUBLIC_) ──
GOOGLE_GEMINI_API_KEY=""

# ── Firebase Admin (server-side only) ──
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ── CORS Config ──
# Comma-separated list of allowed origins (no trailing slashes)
# localhost is auto-allowed in development — only list production/staging here
CORS_ALLOWED_ORIGINS=""

# ── Rate Limiting (requests per minute per IP/user) ──
# All values optional — sensible defaults are built in
RATE_LIMIT_CREATE="10"
RATE_LIMIT_UPLOAD="100"
RATE_LIMIT_PROCESS="5"
RATE_LIMIT_READ="60"
RATE_LIMIT_WRITE="30"
RATE_LIMIT_AUTH="5"
RATE_LIMIT_HEALTH="30"
