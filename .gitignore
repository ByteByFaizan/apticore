# ═══════════════════════════════════════════════
# AptiCore — .gitignore
# ═══════════════════════════════════════════════

# ── Dependencies ──
/node_modules
/.pnp
.pnp.*

# ── Next.js ──
/.next/
/out/
next-env.d.ts

# ── Production Build ──
/build
/dist
/.vercel

# ── TypeScript ──
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Environment Variables (CRITICAL — contains API keys) ──
.env
.env.*
!.env.example
!.env.local.example

# ── Firebase / Google Cloud ──
*-credentials.json
*-service-account*.json
service-account*.json
serviceAccountKey*.json
*.json.key
.firebase/
firebase-debug.log
firestore-debug.log
database-debug.log
ui-debug.log
pubsub-debug.log
storage-debug.log
firebase-export*/

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace
.history/

# ── OS Files ──
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.tmp
*.bak
*.orig

# ── Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Testing / Coverage ──
coverage/
.nyc_output/
*.lcov
__tests__/__snapshots__/

# ── Private Keys / Certs ──
*.pem
*.key
*.cert
*.p12
*.pfx

# ── Python (if used for ML pipeline) ──
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
.env_python/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
*.egg-info/

# ── AI Agent / Tooling ──
.agents/
.clinerules
skills-lock.json
docs/


# ── Gemini / AI Keys (extra safety) ──
*api-key*

# ── Misc ──
*.cache
.eslintcache
.turbo/
.npm/
